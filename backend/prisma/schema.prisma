generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  phone     String   @unique @db.VarChar(20)
  firstName String?  @map("first_name") @db.VarChar(100)
  lastName  String?  @map("last_name") @db.VarChar(100)
  email     String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  applications    Application[]
  loans           Loan[]
  notifications   Notification[]
  paymentRequests PaymentRequest[]

  @@map("users")
}

model OtpCode {
  id        String   @id @default(uuid())
  phone     String   @db.VarChar(20)
  code      String   @db.VarChar(10)
  purpose   String   @db.VarChar(50)
  loanId    String?  @map("loan_id")
  loan      Loan?    @relation(fields: [loanId], references: [id])
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("otp_codes")
}

model Application {
  id          String    @id @default(uuid())
  userId      String?   @map("user_id")
  user        User?     @relation(fields: [userId], references: [id])
  type        String    @db.VarChar(20)
  amount      Decimal   @db.Decimal(12, 2)
  termDays    Int?      @map("term_days")
  termMonths  Int?      @map("term_months")
  status      String    @default("new") @db.VarChar(30)
  firstName   String?   @map("first_name") @db.VarChar(100)
  lastName    String?   @map("last_name") @db.VarChar(100)
  dateOfBirth DateTime? @map("date_of_birth") @db.Date
  email       String?   @db.VarChar(255)
  phone       String?   @db.VarChar(20)
  companyName String?   @map("company_name") @db.VarChar(255)
  regNumber   String?   @map("reg_number") @db.VarChar(100)
  repName     String?   @map("rep_name") @db.VarChar(200)
  repPosition String?   @map("rep_position") @db.VarChar(100)
  comment     String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  loan Loan?

  @@map("applications")
}

model Loan {
  id              String    @id @default(uuid())
  applicationId   String    @unique @map("application_id")
  application     Application @relation(fields: [applicationId], references: [id])
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id])
  amount          Decimal   @db.Decimal(12, 2)
  termDays        Int       @map("term_days")
  dailyRate       Decimal   @default(0.008) @map("daily_rate") @db.Decimal(8, 6)
  dailyPayment    Decimal   @map("daily_payment") @db.Decimal(12, 2)
  totalRepayment  Decimal   @map("total_repayment") @db.Decimal(12, 2)
  paidAmount      Decimal   @default(0) @map("paid_amount") @db.Decimal(12, 2)
  remainingAmount Decimal   @default(0) @map("remaining_amount") @db.Decimal(12, 2)
  status          String    @default("pending_signing") @db.VarChar(30)
  signedAt        DateTime? @map("signed_at")
  signedIp        String?   @map("signed_ip") @db.VarChar(45)
  signedUserAgent String?   @map("signed_user_agent")
  issuedAt        DateTime? @map("issued_at")
  closedAt        DateTime? @map("closed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  schedule        PaymentSchedule[]
  payments        Payment[]
  paymentRequests PaymentRequest[]
  otpCodes        OtpCode[]

  @@map("loans")
}

model PaymentSchedule {
  id             String    @id @default(uuid())
  loanId         String    @map("loan_id")
  loan           Loan      @relation(fields: [loanId], references: [id])
  seq            Int
  dueDate        DateTime  @map("due_date") @db.Date
  amountRequired Decimal   @map("amount") @db.Decimal(12, 2)
  amountPaid     Decimal   @default(0) @map("amount_paid") @db.Decimal(12, 2)
  status  String  @default("UNPAID") @db.VarChar(30)
  paidAt         DateTime? @map("paid_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@unique([loanId, seq])
  @@map("payment_schedule")
}

model Payment {
  id         String    @id @default(uuid())
  loanId     String    @map("loan_id")
  loan       Loan      @relation(fields: [loanId], references: [id])
  amount     Decimal   @db.Decimal(12, 2)
  status     String    @default("success") @db.VarChar(20)
  recordedAt DateTime  @map("recorded_at")
  recordedBy String    @map("recorded_by")
  adminUser  AdminUser @relation(fields: [recordedBy], references: [id])
  note       String?
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("payments")
}

model PaymentRequest {
  id         String     @id @default(uuid())
  loanId     String     @map("loan_id")
  loan       Loan       @relation(fields: [loanId], references: [id])
  userId     String     @map("user_id")
  user       User       @relation(fields: [userId], references: [id])
  amount     Decimal    @db.Decimal(12, 2)
  reference  String
  status     String     @default("pending") @db.VarChar(20)
  reviewedBy String?    @map("reviewed_by")
  adminUser  AdminUser? @relation(fields: [reviewedBy], references: [id])
  reviewedAt DateTime?  @map("reviewed_at")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  @@map("payment_requests")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(255)
  body      String?
  isRead    Boolean  @default(false) @map("is_read")
  relatedId String?  @map("related_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

model AdminUser {
  id           String   @id @default(uuid())
  login        String   @unique @db.VarChar(100)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         String   @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")

  payments        Payment[]
  paymentRequests PaymentRequest[]

  @@map("admin_users")
}
